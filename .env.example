# Copy to .env and fill in. .env is gitignored.
OPENAI_API_KEY=sk-...

# Orchestrator + embedding models (override as desired)
ADVISOR_CHAT_MODEL=gpt-4.1
ADVISOR_EMBED_MODEL=text-embedding-3-small

# Data location (relative to repo root)
ADVISOR_DATA_DIR=data

# --- Backend (FastAPI) ---
# MongoDB for users/conversations/messages (Atlas or Railway)
MONGODB_URI=mongodb+srv://user:pass@cluster/...
MONGODB_DATABASE=advising_bot
# Secret for JWT signing AND password hashing — keep stable or all logins break
JWT_SECRET_KEY=change-me-in-production
# Comma-separated origins allowed by CORS (your Vercel URL + localhost)
ALLOWED_ORIGINS=http://localhost:3000
# PORT is injected by Railway; defaults to 8000 locally
# PORT=8000
